{
  "manifest_version": 3,
  "name": "Link Opener",
  "version": "1.0.1",
  "description": "Save and reopen browser sessions. Import URL lists to open as windows, or export your current Firefox windows into shareable URL lists.",
  "author": "Link Opener",

  "permissions": ["storage", "tabs", "alarms", "downloads"],

  "action": {
    "default_title": "Link Opener",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "link-opener@extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
